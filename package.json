{
  "name": "iassistente-poc",
  "version": "1.0.0",
  "description": "iAssistente - Voice-to-Text Notes App",
  "private": true,
  "scripts": {
    "branch": "node scripts/create-branch.js",
    "commit": "cz",
    "lint:prettier:check": "cd backend && prettier --check . && cd ../frontend && prettier --check .",
    "lint:prettier:fix": "cd backend && prettier --write . && cd ../frontend && prettier --write .",
    "lint:eslint:check": "cd backend && eslint . && cd ../frontend && eslint .",
    "lint:eslint:fix": "cd backend && eslint . --fix && cd ../frontend && eslint . --fix",
    "lint:secretlint:check": "npx secretlint \"**/*\"",
    "prepare": "husky"
  },
  "author": "Victoria",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@secretlint/secretlint-rule-aws": "^11.2.5",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.4",
    "next": "^16.2.9",
    "prettier": "^3.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "secretlint": "^11.2.5"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
