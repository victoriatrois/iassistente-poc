{
  "name": "iassistente-poc",
  "version": "1.0.0",
  "description": "iAssistente - Voice-to-Text Notes App",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "branch": "node scripts/create-branch.js",
    "commit": "cz",
    "dev": "npm --workspace=backend run dev",
    "dev:backend": "npm --workspace=backend run dev",
    "dev:frontend": "npm --workspace=frontend run start",
    "build": "npm --workspace=backend run build",
    "build:backend": "npm --workspace=backend run build",
    "build:frontend": "npm --workspace=frontend run build",
    "start": "npm --workspace=backend run start",
    "start:backend": "npm --workspace=backend run start",
    "test": "npm --workspace=backend run test && npm --workspace=frontend run test",
    "test:backend": "npm --workspace=backend run test",
    "test:backend:watch": "npm --workspace=backend run test:watch",
    "test:frontend": "npm --workspace=frontend run test",
    "lint": "npm run lint:prettier:check && npm run lint:eslint:check",
    "lint:prettier:check": "prettier --check \"backend/**/*.{ts,tsx,js,json,md}\" \"frontend/**/*.{ts,tsx,js,json,md}\"",
    "lint:prettier:fix": "prettier --write \"backend/**/*.{ts,tsx,js,json,md}\" \"frontend/**/*.{ts,tsx,js,json,md}\"",
    "lint:eslint:check": "npm --workspace=backend run lint && npm --workspace=frontend run lint",
    "lint:eslint:fix": "npm --workspace=backend run lint -- --fix && npm --workspace=frontend run lint -- --fix",
    "lint:secretlint:check": "secretlint \"**/*\"",
    "lint:backend": "npm --workspace=backend run lint",
    "lint:frontend": "npm --workspace=frontend run lint",
    "migrate:create": "npm --workspace=backend run migrate:create",
    "migrate:up": "npm --workspace=backend run migrate:up",
    "services:up": "docker-compose -f infra/docker-compose.yml up -d",
    "services:down": "docker-compose -f infra/docker-compose.yml down",
    "services:stop": "docker-compose -f infra/docker-compose.yml stop",
    "services:logs": "docker-compose -f infra/docker-compose.yml logs -f",
    "services:ps": "docker-compose -f infra/docker-compose.yml ps",
    "prepare": "husky"
  },
  "author": "Victoria",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@secretlint/secretlint-rule-aws": "^11.2.5",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "@types/node": "^20.19.43",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.4",
    "next": "16.2.9",
    "prettier": "^3.3.3",
    "secretlint": "^11.2.5",
    "typescript": "^5"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
